{
  "manifest_version": 3,
  "name": "Haul: Shopping Comparison Tool",
  "version": "0.3.0",
  "description": "Save products from any shopping site. Compare side-by-side. Stop the tab chaos.",
  "minimum_chrome_version": "114",
  "permissions": [
    "storage",
    "sidePanel",
    "tabs",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://haul-ai.haulapp.workers.dev/*",
    "https://haul-production.up.railway.app/*"
  ],
  "optional_host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Haul"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.amazon.com/*",
        "https://*.amazon.co.uk/*",
        "https://*.nike.com/*",
        "https://*.asos.com/*",
        "https://*.target.com/*",
        "https://*.bestbuy.com/*",
        "https://*.zara.com/*",
        "https://*.hm.com/*",
        "https://*.nordstrom.com/*",
        "https://*.wayfair.com/*",
        "https://*.ebay.com/*",
        "https://*.adidas.com/*",
        "https://*.converse.com/*",
        "https://*.pacsun.com/*",
        "https://*.walmart.com/*",
        "https://*.costco.com/*",
        "https://*.homedepot.com/*",
        "https://*.macys.com/*",
        "https://*.uniqlo.com/*",
        "https://*.gap.com/*",
        "https://*.oldnavy.com/*",
        "https://*.urbanoutfitters.com/*",
        "https://*.forever21.com/*"
      ],
      "js": ["lib/product-schema.js", "lib/extractor.js", "content-script.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["https://haul-production.up.railway.app/*"],
      "js": ["lib/product-schema.js", "account-bridge.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
