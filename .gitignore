# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Dependencies
node_modules/

# Build outputs and caches
dist/
build/
.next/
.vite/
.turbo/
.cache/
coverage/
.vercel/
.railway/
out/

# Environment files — NEVER commit secrets
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor / OS metadata
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo
*~

# Temporary files
tmp/
temp/
*.tmp

# Archives and zip builds — use releases instead
*.zip
*.tar.gz
*.tgz
*.rar
*.7z

# Office temp files (Word, Excel, etc.)
~$*
*.~*

# Cloudflare Wrangler
.wrangler/
wrangler.toml.local

# Extension build copies
haul-extension copy/
haul-extension copy*/

# Clerk / auth secrets (extra safety)
.clerk/

